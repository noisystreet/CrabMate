{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "crabmate",
  "version": "0.1.0",
  "identifier": "com.crabmate.desktop",
  "build": {
    "beforeDevCommand": "bash ./scripts/prepare-sidecar.sh",
    "beforeBuildCommand": "bash ./scripts/prepare-sidecar.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb"
    ],
    "externalBin": [
      "../binaries/crabmate"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "files": {
          "usr/share/applications/crabmate.desktop": "bundle/deb/crabmate.desktop"
        }
      }
    }
  }
}
