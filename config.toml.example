# Agent Demo 配置示例（覆盖 default_config.toml 中的默认值）
# 复制为 config.toml 或 .agent_demo.toml 后按需修改
# 环境变量 AGENT_* 会覆盖对应项（如 AGENT_REFLECTION_DEFAULT_MAX_ROUNDS）

[agent]
# api_base = "https://api.deepseek.com/v1"
# model = "deepseek-chat"
# max_message_history = 24
# tui_load_session_on_start = false
# tui_session_max_messages = 400
# tool_message_max_chars = 32768
# context_char_budget = 0
# context_summary_trigger_chars = 0
# chat_queue_max_concurrent = 2
# chat_queue_max_pending = 32
# conversation_store_sqlite_path = ".crabmate/conversations.db"
# agent_memory_file_enabled = true
# agent_memory_file = ".crabmate/agent_memory.md"
# agent_memory_file_max_chars = 8000
# command_timeout_secs = 10
# command_max_output_len = 8192
# allowed_commands = ["ls", "pwd", "whoami", "date", "echo", "id", "uname", "env", "file", "df", "du", "head", "tail", "wc", "cat"]
# run_command_working_dir = "."
# web_api_bearer_token = "YOUR_STRONG_RANDOM_TOKEN"
# allow_insecure_no_auth_for_non_loopback = false
# max_tokens = 2048
# temperature = 0.7
# api_timeout_secs = 60
# api_max_retries = 3
# api_retry_delay_secs = 1
# weather_timeout_secs = 15
# web_search_provider = "brave"   # brave | tavily
# web_search_api_key = "YOUR_BRAVE_OR_TAVILY_KEY"
# web_search_timeout_secs = 30
# web_search_max_results = 8
# http_fetch_allowed_prefixes = ["https://doc.rust-lang.org/"]
# http_fetch_timeout_secs = 30
# http_fetch_max_response_bytes = 524288
# reflection_default_max_rounds = 5
# final_plan_requirement = "workflow_reflection"  # never | workflow_reflection | always（实验性，每轮终答均校验）
# plan_rewrite_max_attempts = 2
# planner_executor_mode = "single_agent"  # single_agent | logical_dual_agent（阶段1：同进程逻辑双agent）
# staged_plan_execution = false   # true：先无工具产出 agent_reply_plan，再按步执行
# staged_plan_phase_instruction = """……"""  # 可选；空则用内置规划轮说明
# cursor_rules_enabled = false    # true：自动拼接 cursor_rules_dir/*.mdc 到 system_prompt
# cursor_rules_dir = ".cursor/rules"
# cursor_rules_include_agents_md = true
# cursor_rules_max_chars = 48000
# system_prompt = "你是专业的助手，回答简洁。"
# system_prompt_file = "system_prompt.txt"
model = "deepseek-chat"
