# Agent Demo 配置示例（覆盖 default_config.toml 中的默认值）
# 复制为 config.toml 或 .agent_demo.toml 后按需修改
# 环境变量 AGENT_* 会覆盖对应项（如 AGENT_REFLECTION_DEFAULT_MAX_ROUNDS）

[agent]
# api_base = "https://api.deepseek.com/v1"
# model = "deepseek-chat"
# 本地 Ollama（OpenAI 兼容）：api_base = "http://127.0.0.1:11434/v1" 且 llm_http_auth_mode = "none" 时可不设 API_KEY
# llm_http_auth_mode = "none"
# max_message_history = 24
# tui_load_session_on_start = false
# tui_session_max_messages = 400
# tool_message_max_chars = 32768
# tool_result_envelope_v1 = true
# materialize_deepseek_dsml_tool_calls = true
# context_char_budget = 200000
# parallel_readonly_tools_max = 4
# read_file_turn_cache_max_entries = 64   # 0 关闭单轮 read_file 缓存；AGENT_READ_FILE_TURN_CACHE_MAX_ENTRIES
# context_summary_trigger_chars = 0
# chat_queue_max_concurrent = 2
# chat_queue_max_pending = 32
# conversation_store_sqlite_path = ".crabmate/conversations.db"
# agent_memory_file_enabled = true
# agent_memory_file = ".crabmate/agent_memory.md"
# agent_memory_file_max_chars = 8000
# project_profile_inject_enabled = true
# project_profile_inject_max_chars = 6000
# tool_call_explain_enabled = false
# tool_call_explain_min_chars = 8
# tool_call_explain_max_chars = 400
# 长期记忆（默认开启 + fastembed；仅文本、不要向量时可设 vector_backend = "disabled"）
# long_term_memory_enabled = true
# long_term_memory_scope_mode = "conversation"
# long_term_memory_vector_backend = "fastembed"
# long_term_memory_max_entries = 256
# long_term_memory_inject_max_chars = 8000
# long_term_memory_store_sqlite_path = ".crabmate/long_term_memory.db"
# long_term_memory_top_k = 8
# long_term_memory_async_index = true
# command_timeout_secs = 10
# command_max_output_len = 8192
# allowed_commands：逗号分隔命令名，覆盖默认白名单（见 default_config.toml；含 stat/grep/diff/git/cargo、文本与压缩只读工具等）
# AGENT_ALLOWED_COMMANDS=ls,pwd,git,grep
# run_command_working_dir = "."
# web_api_bearer_token = "YOUR_STRONG_RANDOM_TOKEN"
# allow_insecure_no_auth_for_non_loopback = false
# max_tokens = 2048
# temperature = 0.7
# llm_seed = 42   # 可选；写入 chat/completions 的 seed；省略则不带该字段
# api_timeout_secs = 60
# api_max_retries = 3
# api_retry_delay_secs = 1
# weather_timeout_secs = 15
# web_search_provider = "brave"   # brave | tavily
# web_search_api_key = "YOUR_BRAVE_OR_TAVILY_KEY"
# web_search_timeout_secs = 30
# web_search_max_results = 8
# MCP（stdio 子进程客户端）：每轮对话连接一次，合并远端 tools/list；须显式启用并配置命令行（等效允许启动任意子进程，仅用于可信配置）
# mcp_enabled = true
# mcp_command = "npx -y @modelcontextprotocol/server-filesystem /path/to/sandbox"
# mcp_tool_timeout_secs = 60   # 默认与 command_timeout_secs 相同

# http_fetch_allowed_prefixes = ["https://doc.rust-lang.org/"]
# http_fetch_timeout_secs = 30
# http_fetch_max_response_bytes = 524288
# reflection_default_max_rounds = 5
# final_plan_requirement = "workflow_reflection"  # never | workflow_reflection | always（实验性，每轮终答均校验）
# plan_rewrite_max_attempts = 2
# planner_executor_mode = "single_agent"  # single_agent | logical_dual_agent（阶段1：同进程逻辑双agent）
# staged_plan_execution = false   # true：先无工具产出 agent_reply_plan，再按步执行
# staged_plan_allow_no_task = true   # 内置规划说明是否包含「无具体任务则 no_task + 空 steps」；AGENT_STAGED_PLAN_ALLOW_NO_TASK
# staged_plan_phase_instruction = """……"""  # 可选；空则用内置规划轮说明
# staged_plan_feedback_mode = "fail_fast"   # fail_fast | patch_planner；AGENT_STAGED_PLAN_FEEDBACK_MODE
# staged_plan_patch_max_attempts = 2        # patch_planner 下每步最多补丁规划轮次数；AGENT_STAGED_PLAN_PATCH_MAX_ATTEMPTS
# staged_plan_cli_show_planner_stream = true   # CLI 是否打印规划轮模型 stdout；false=仅队列/分步转录；AGENT_STAGED_PLAN_CLI_SHOW_PLANNER_STREAM
# cursor_rules_enabled = false    # true：自动拼接 cursor_rules_dir/*.mdc 到 system_prompt
# cursor_rules_dir = ".cursor/rules"
# cursor_rules_include_agents_md = true
# cursor_rules_max_chars = 48000
# 默认与 default_config 一致：system_prompt_file = "prompts/default_system_prompt.md"（改该文件无需重编）
# 仅写内联会取消默认文件路径，例如：# system_prompt = "你是专业的助手，回答简洁。"
# system_prompt_file = "system_prompt.txt"   # 相对路径解析见 docs/CONFIGURATION.md「系统提示词」
model = "deepseek-chat"
